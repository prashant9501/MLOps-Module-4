# ============================================================
# SBERT News Search -- .dockerignore
#
# Files and directories to exclude from the Docker build context.
# This reduces build time and image size by keeping unnecessary
# files out of the container.
# ============================================================

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.pytest_cache/

# Virtual environments (never ship these in containers)
.venv/
venv/
env/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Docker files (no need to copy into the image)
Dockerfile
docker-compose.yml
.dockerignore

# Documentation
*.md

# Jupyter notebooks and checkpoints
*.ipynb
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Large data files that should be volume-mounted, not baked in
# Uncomment the lines below if you want to volume-mount data instead:
# data/raw/
# models/*.annoy
